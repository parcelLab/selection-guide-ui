{
  "name": "@jkrenge/size-recommender-ui",
  "version": "0.1.0",
  "description": "Embeddable size recommender widget for retailer PDPs.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/size-recommender.esm.js",
      "default": "./dist/size-recommender.iife.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && node scripts/build.mjs && tsc -p tsconfig.types.json",
    "dev": "node scripts/dev.mjs",
    "test": "vitest run --environment jsdom"
  },
  "devDependencies": {
    "esbuild": "^0.25.1",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
